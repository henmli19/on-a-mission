--- !u!114 &501236771
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 501236769}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 57485eca685d59246b56348c49ac2464, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textBox: {fileID: 501236772}
  fullText: "This city used to have people in it. They didn't leave all at once \u2014
    it was slow. One family, then another, until the streets just stayed quiet. The
    drones were already running by then, patrolling like they were still protecting
    someone. Whatever sent them \u2014 it came from underground. Past the deep sector.
    And whatever's down there, the machines won't let anyone near it.                                           "
  typingSpeed: 0.05
